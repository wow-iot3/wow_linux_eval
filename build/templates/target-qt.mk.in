# this file is generated by mbuild_project from mbuild system, see more in build/README.md
LOCAL_PATH := $(call my-dir)
include $(CLEAR_VARS)

# 在编译QT应用时,模块名称是mk所在目录的名称(相对于工程根目录) 
LOCAL_MODULE := 

# qmake所在路径,编译时根据此路径查找相关工具
QMAKE_PATH :=

# c compile flags
LOCAL_CFLAGS :=

# cpp compile flags
LOCAL_CXXFLAGS :=

# open libs type, for example: x86_64-gcc8.3 
OPENLIBS_TYPE := 

# link flags, for example: -lpthread
ifneq ($(OPENLIBS_TYPE),)
LOCAL_LDFLAGS := -Wl,-rpath-link $(PROJECT_ROOT)/openlibs/sysroot/$(OPENLIBS_TYPE)
endif
LOCAL_LDFLAGS +=

# lib path
LOCAL_LIB_PATHS :=

# include file list
LOCAL_INC_PATHS := \
	$(LOCAL_PATH)

# 在编译QT应用时,LOCAL_SRC_FILES指当前目录下(.mk文件所在目录)的QT工程名称,
# 注意：这里的名称不需要后缀.pro,如demo.pro只需要填写demo即可!!!
LOCAL_SRC_FILES :=

# 如果qt工程包含子工程,则需要指定子工程目标文件路径(如:subproj-demo1/demo1,不需要.pro后缀).
LOCAL_TARGETS :=

LOCAL_PRE_BUILD :=
LOCAL_POST_BUILD :=
include $(BUILD_QTPROJECT)
