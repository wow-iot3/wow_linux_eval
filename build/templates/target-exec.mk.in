# this file is generated by mbuild_project from mbuild system, see more in build/README.md
LOCAL_PATH := $(call my-dir)
include $(CLEAR_VARS)

# module name
LOCAL_MODULE := 

# c compile flags
LOCAL_CFLAGS :=

# cpp compile flags
LOCAL_CXXFLAGS :=

# open libs type, for example: x86_64-gcc8.3 
OPENLIBS_TYPE := 

# link flags, for example: -lpthread
ifneq ($(OPENLIBS_TYPE),)
LOCAL_LDFLAGS := -Wl,-rpath-link $(PROJECT_ROOT)/openlibs/sysroot/$(OPENLIBS_TYPE)
endif
LOCAL_LDFLAGS +=

# lib path
LOCAL_LIB_PATHS :=

# include file list
LOCAL_INC_PATHS := \
	$(LOCAL_PATH)

# source file list
LOCAL_SRC_FILES := \

LOCAL_PRE_BUILD :=
LOCAL_POST_BUILD :=
include $(BUILD_EXECUTABLE)
